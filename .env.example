# Salambo CLI deploy/smoke
# App/API base URL without /api/v1.
SALAMBO_BASE_URL=https://YOUR_SALAMBO_BASE_URL
SALAMBO_API_KEY=

# Agent secrets referenced by salambo.yaml.
# These are synced by `salambo deploy --source .`; they are not consumed by a
# sandbox-hosted brain because the brain runs in the Salambo worker.
OPENAI_API_KEY=

# Local sandbox settings.
WORKSPACE_DIR=/workspace

# Optional managed egress CA injected by Salambo in hosted runs.
# Usually leave empty locally.
EGRESS_PROXY_CA_CERT_PEM=
EGRESS_PROXY_CA_CERT_PEM_B64=
