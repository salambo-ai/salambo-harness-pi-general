# ── Required ──────────────────────────────────────
# API key for the model provider (used by the runtime on startup)
OPENAI_API_KEY=

# ── Salambo CLI deploy/smoke ──────────────────────
# App/API base URL without /api/v1
SALAMBO_BASE_URL=https://YOUR_SALAMBO_BASE_URL
SALAMBO_API_KEY=

# ── Server ────────────────────────────────────────
PORT=3000
WORKSPACE_DIR=/workspace

# ── Platform (set by Salambo) ─────────────────────
# S2 StreamStore for production event streaming
S2_ACCESS_TOKEN=
S2_BASIN=
S2_STREAM_PREFIX=agent-session

# File sync gateway
GATEWAY_BASE_URL=

# ── Optional ──────────────────────────────────────
# Override pi agent home directory (defaults to ./harness-config/pi-agent-home)
PI_HOME=

# Local event buffer size when S2 is disabled
LOCAL_EVENT_MAX_EVENTS=500

# File watcher stability threshold (ms)
FILE_WATCH_STABILITY_MS=2000

# Sandbox logging
SANDBOX_FILE_LOGGING=true
SANDBOX_LOG_DIR=/tmp/sandbox-logs
