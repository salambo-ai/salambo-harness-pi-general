{
  "name": "salambo-harness-pi-general",
  "version": "2.1.0",
  "description": "Hands-only Salambo sandbox template for worker-owned Pi runs",
  "type": "module",
  "scripts": {
    "test": "npm run sandbox:validate",
    "typecheck": "npm run sandbox:validate",
    "sandbox:validate": "node scripts/materialize-sandbox-config.mjs --check",
    "sandbox:materialize": "node scripts/materialize-sandbox-config.mjs",
    "docker:build": "docker build -t salambo-harness-pi-general .",
    "docker:run": "docker run --rm salambo-harness-pi-general"
  },
  "keywords": [
    "salambo",
    "pi",
    "sandbox",
    "daytona",
    "extensions"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {}
}
