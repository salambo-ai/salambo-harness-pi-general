{
  "name": "salambo-sandbox-pi-sdk",
  "version": "2.0.4",
  "description": "Dockerized sandbox template for @mariozechner/pi-coding-agent with the Salambo HTTP API",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit",
    "harness:validate": "tsx -e \"import { getImageConfig } from './src/platform/load-image-config'; getImageConfig(); console.log('Harness config OK');\"",
    "harness:materialize": "node --import tsx scripts/materialize-image-config.mjs",
    "docker:build": "docker build -t salambo-sandbox-pi-sdk .",
    "docker:run": "docker run -p 3000:3000 salambo-sandbox-pi-sdk",
    "image:build": "node scripts/docker-image.mjs build",
    "image:push": "node scripts/docker-image.mjs push",
    "image:release": "node scripts/docker-image.mjs release",
    "image:print": "node scripts/docker-image.mjs print",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down"
  },
  "keywords": [
    "pi",
    "agent",
    "sandbox",
    "docker",
    "openai",
    "node"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@s2-dev/streamstore": "^0.17.3",
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "undici": "^7.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/node": "^22.18.6",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
